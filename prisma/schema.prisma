generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int             @id @default(autoincrement())
  username     String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  movements    StockMovement[]
  aiConfig     UserAiConfig?

  @@map("users")
}

model UserAiConfig {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  apiUrl        String
  model         String
  apiKeyCipher  String
  apiKeyIv      String
  apiKeyAuthTag String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_ai_configs")
}

model Product {
  id        Int      @id @default(autoincrement())
  styleNo   String   @unique
  name      String
  supplier  String?
  category  String?
  brand     String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skus      Sku[]

  @@map("products")
}

model Sku {
  id               Int               @id @default(autoincrement())
  productId        Int
  color            String
  size             String
  barcode          String?
  retailPrice      Decimal?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryBalance InventoryBalance?
  inboundItems     InboundOrderItem[]
  outboundItems    OutboundOrderItem[]
  customerOrderItems CustomerOrderItem[]
  movements        StockMovement[]

  @@unique([productId, color, size])
  @@map("skus")
}

model InventoryBalance {
  id        Int      @id @default(autoincrement())
  skuId     Int      @unique
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@map("inventory_balances")
}

model InboundOrder {
  id          Int                @id @default(autoincrement())
  supplier    String
  inboundDate DateTime
  note        String?
  createdAt   DateTime           @default(now())
  items       InboundOrderItem[]
  movements   StockMovement[]

  @@map("inbound_orders")
}

model InboundOrderItem {
  id             Int          @id @default(autoincrement())
  inboundOrderId Int
  skuId          Int
  quantity       Int
  unitCost       Decimal
  inboundOrder   InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  sku            Sku          @relation(fields: [skuId], references: [id])

  @@map("inbound_order_items")
}

model OutboundOrder {
  id           Int                 @id @default(autoincrement())
  customer     String
  channel      String?
  outboundDate DateTime
  note         String?
  createdAt    DateTime            @default(now())
  items        OutboundOrderItem[]
  movements    StockMovement[]
  customerOrder CustomerOrder?

  @@map("outbound_orders")
}

model OutboundOrderItem {
  id              Int           @id @default(autoincrement())
  outboundOrderId Int
  skuId           Int
  quantity        Int
  unitPrice       Decimal
  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  sku             Sku           @relation(fields: [skuId], references: [id])

  @@map("outbound_order_items")
}

model CustomerOrder {
  id              Int                 @id @default(autoincrement())
  customer        String
  orderNo         String?
  channel         String?
  orderDate       DateTime
  note            String?
  status          String              @default("PENDING")
  shippedAt       DateTime?
  outboundOrderId Int?                @unique
  amountDue       Decimal             @default(0)
  paidAmount      Decimal             @default(0)
  unpaidAmount    Decimal             @default(0)
  changeAmount    Decimal             @default(0)
  paymentWechat   Decimal             @default(0)
  paymentCash     Decimal             @default(0)
  paymentAlipay   Decimal             @default(0)
  paymentCard     Decimal             @default(0)
  paymentScan     Decimal             @default(0)
  paymentTransfer Decimal             @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  items           CustomerOrderItem[]
  outboundOrder   OutboundOrder?      @relation(fields: [outboundOrderId], references: [id])

  @@map("customer_orders")
}

model CustomerOrderItem {
  id              Int           @id @default(autoincrement())
  customerOrderId Int
  skuId           Int
  quantity        Int
  unitPrice       Decimal
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  sku             Sku           @relation(fields: [skuId], references: [id])

  @@map("customer_order_items")
}

model StockMovement {
  id              Int            @id @default(autoincrement())
  skuId           Int
  type            String
  quantityChange  Int
  balanceAfter    Int
  inboundOrderId  Int?
  outboundOrderId Int?
  operatorId      Int?
  createdAt       DateTime       @default(now())
  sku             Sku            @relation(fields: [skuId], references: [id])
  inboundOrder    InboundOrder?   @relation(fields: [inboundOrderId], references: [id])
  outboundOrder   OutboundOrder?  @relation(fields: [outboundOrderId], references: [id])
  operator        User?          @relation(fields: [operatorId], references: [id])

  @@map("stock_movements")
}
