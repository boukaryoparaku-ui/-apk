# ====== 服装供销存系统 环境变量 ======
# 复制本文件为 .env 后按需修改。.env 已被忽略，不会进仓库/镜像。

# 运行环境，生产固定 production
NODE_ENV=production

# 应用监听端口
PORT=3000

# 时区，影响流水/打印的时间显示
TZ=Asia/Shanghai

# 数据库：现在用 SQLite，DATABASE_URL 指向一个文件即可。
# 注意：Prisma 解析 file: 相对路径时基准是 prisma/ 目录（schema 所在处），
# 所以 file:./data.db 实际落在 prisma/data.db。CLI 和运行时都按这个规则，保持一致。
# 不需要再装/连 PostgreSQL。备份就是复制这个 .db 文件。
DATABASE_URL=file:./data.db

# 登录会话持久化目录（session-file-store），默认 ./sessions
# SESSION_STORE_DIR=./sessions

# 登录会话签名密钥，务必改成随机长串：openssl rand -hex 32
SESSION_SECRET=请改成一串随机字符串

# AI API Key 的加密密钥，单独设置，和 SESSION_SECRET 解耦
# 一旦设定不要随意更改，否则数据库里已加密保存的 AI Key 会无法解密
AI_CONFIG_SECRET=请改成另一串随机字符串

# 初始管理员账号。仅在首次启动、库中尚无该用户时创建一次
# admin 已存在后，改这里不会改密码；请到「设置 → 账号管理」里改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成你的初始密码

# PDF 打印用的中文字体路径（可选）
# PDF_FONT_PATH=
