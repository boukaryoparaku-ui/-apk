# ====== 生产环境配置模板 ======
# 复制本文件为 .env 后修改敏感信息
#
# 快速生成随机密钥：
#   openssl rand -hex 32

# ========== 安全配置（必须修改） ==========

# 登录会话签名密钥 - 务必改成随机长字符串
# 生成方法: openssl rand -hex 32
SESSION_SECRET=请改成随机字符串

# AI API Key 加密密钥 - 务必改成另一个随机长字符串
# 警告：一旦设定不要随意更改，否则数据库中的 AI Key 无法解密
# 生成方法: openssl rand -hex 32
AI_CONFIG_SECRET=请改成另一个随机字符串

# 初始管理员账号（仅首次启动生效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成强密码

# ========== 应用配置 ==========

# 时区（影响订单时间显示）
TZ=Asia/Shanghai

# 宿主机监听端口（访问地址中的端口）
# 例如：3001 表示通过 http://服务器IP:3001 访问
# 如果使用反向代理(Nginx/Caddy)，可以改成 127.0.0.1:3001 只允许本机访问
HOST_PORT=3001

# ========== 数据库配置 ==========
# Docker 部署时使用卷挂载，无需修改
DATABASE_URL=file:/data/data.db

# ========== 高级配置（可选） ==========

# PDF 中文字体路径（如需自定义字体）
# PDF_FONT_PATH=/data/fonts/NotoSansSC-Regular.ttf

# Node.js 内存限制（单位：MB）
# NODE_OPTIONS=--max-old-space-size=512
